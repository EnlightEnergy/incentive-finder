modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["glibcLocales"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 33081
externalPort = 3002

[[ports]]
localPort = 33641
externalPort = 8000

[[ports]]
localPort = 34253
externalPort = 5173

[[ports]]
localPort = 34491
externalPort = 4200

[[ports]]
localPort = 34657
externalPort = 8099

[[ports]]
localPort = 36159
externalPort = 8008

[[ports]]
localPort = 36201
externalPort = 5000

[[ports]]
localPort = 37937
externalPort = 3001

[[ports]]
localPort = 38617
externalPort = 9000

[[ports]]
localPort = 41105
externalPort = 3000

[[ports]]
localPort = 41967
externalPort = 6800

[[ports]]
localPort = 44055
externalPort = 3003

[[ports]]
localPort = 44941
externalPort = 8081

[[ports]]
localPort = 45635
externalPort = 8080

[[ports]]
localPort = 45881
externalPort = 6000

[env]
PORT = "5000"

[agent]
integrations = ["javascript_openai:1.0.0", "javascript_sendgrid:1.0.0", "javascript_database:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000
